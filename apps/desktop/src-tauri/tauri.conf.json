{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidcord",
  "version": "0.1.1",
  "identifier": "com.sidcord.desktop",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --dir ../web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sidcord",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxODIyRDdFMkI5RjY5RQpSV1NlOXJuaTF5SVlENm1MVmtqZ2FGZDlNVnBPRDR4UnFDMzZGTkFDOEVENW1kcHdValltWEpqbQo=",
      "endpoints": [
        "https://github.com/slymnysr/sidcord/releases/latest/download/latest.json"
      ]
    }
  }
}
